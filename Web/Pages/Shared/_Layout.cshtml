<!DOCTYPE html>

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>
            @(ViewData["Title"] as string) - Web
        </title>

        <script type="importmap"></script>

        <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
        <link href="~/lib/font-awesome/css/all.css" rel="stylesheet" type="text/css" />
        <link asp-append-version="true" href="~/css/site.css" rel="stylesheet" type="text/css" />
        <link asp-append-version="true" href="~/Web.styles.css" rel="stylesheet" type="text/css" />

        <script asp-append-version="false" defer src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" type="text/javascript"></script>
        <script asp-append-version="true" defer src="~/js/site.js" type="text/javascript"></script>
    </head>
    <body>
        <header>
            @await Html.PartialAsync(
                partialViewName: "~/Pages/Shared/Partial/_Navbar.cshtml"
            )
        </header>

        <main class="container" role="main">
            <div class="pb-3">
                @RenderBody()
            </div>
        </main>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Web - <a asp-area="" asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    </body>
</html>