<!DOCTYPE html>

<html lang="en">
    <head>
        @* meta charset|http-equivalent|viewport *@
        <meta charset="utf-8" />
        <meta http-equiv="content-type" content="text/html; charset=UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        @* title *@
        <title>
            @Environment.GetEnvironmentVariable(variable: "WebsiteName") | @(ViewData["Title"] as string)
        </title>

        @* preconnect *@
        @* n/a *@

        @* script async *@
        @* n/a *@

        @* CSS que incluye @import *@
        @* n/a *@

        @* JS Sincrónico *@
        @* n/a *@

        @* CSS Sincrónico *@
        <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" fetchpriority="high" hreflang="en" lang="en" rel="stylesheet" type="text/css" />
        <link href="~/lib/font-awesome/css/all.css" fetchpriority="high" hreflang="en" lang="en" rel="stylesheet" type="text/css" />

        @* preload *@
        @* n/a *@

        @* script defer *@
        <script charset="utf-8" crossorigin="anonymous" defer fetchpriority="high" lang="en" src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" type="text/javascript"></script>

        @* prefetch / prerender *@
        @* n/a *@

        @* Todo lo demás ('SEO', meta tags, icons, Open Graph, etc) *@
        @* n/a *@
    </head>
    <body>
        <header>
            @await Html.PartialAsync(
                partialViewName: "~/Pages/Shared/Partial/_Navbar.cshtml"
            )
        </header>

        <main class="container" role="main">
            @RenderBody()
        </main>
    </body>
</html>